FROM node:22-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash curl netcat-openbsd procps iproute2 uuid-runtime python3 openssl ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Install Claude Code + proxychains (force all TCP through proxy at libc level)
RUN npm install -g @anthropic-ai/claude-code
RUN apt-get update && apt-get install -y --no-install-recommends proxychains4 && rm -rf /var/lib/apt/lists/*

WORKDIR /opt/cac

# Copy project
COPY src/ src/
COPY build.sh .
COPY package.json .

# Build cac
RUN bash build.sh

# Add cac to PATH
ENV PATH="/opt/cac:$PATH"

# Create bashrc
RUN touch /root/.bashrc

ENTRYPOINT ["bash"]
