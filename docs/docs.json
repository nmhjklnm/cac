{
  "$schema": "https://mintlify.com/docs.json",
  "name": "cac",
  "description": "Isolate, protect, and manage your Claude Code",
  "theme": "maple",
  "colors": {
    "primary": "#D97706",
    "light": "#FBBF24",
    "dark": "#B45309"
  },
  "logo": {
    "light": "/images/logo-light.svg",
    "dark": "/images/logo-dark.svg"
  },
  "favicon": "/images/favicon.png",
  "navbar": {
    "links": [
      {
        "label": "GitHub",
        "href": "https://github.com/nmhjklnm/cac"
      }
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/nmhjklnm/cac"
    }
  },
  "rounded": "default",
  "contextual": {
    "options": [
      "copy",
      "view",
      "claude",
      "chatgpt",
      {
        "title": "GitHub Issues",
        "description": "Report a bug or request a feature",
        "icon": "github",
        "iconType": "brands",
        "href": "https://github.com/nmhjklnm/cac/issues"
      }
    ]
  },
  "tabs": [
    {
      "id": "guides",
      "name": "Guides",
      "icon": "book"
    },
    {
      "id": "reference",
      "name": "Reference",
      "icon": "code"
    }
  ],
  "navigation": {
    "groups": [
      {
        "group": "Get started",
        "pages": [
          "index",
          "quickstart",
          "concepts"
        ]
      },
      {
        "group": "Commands",
        "pages": [
          "commands/claude",
          "commands/env",
          "commands/self",
          "commands/docker"
        ]
      }
    ],
    "tabs": {
      "guides": [
        {
          "group": "Guides",
          "pages": [
            "guides/proxy-setup",
            "guides/api-key-users",
            "guides/docker-mode",
            "guides/migrating"
          ]
        }
      ],
      "reference": [
        {
          "group": "Reference",
          "pages": [
            "reference/file-layout",
            "reference/how-it-works",
            "reference/privacy-layers"
          ]
        }
      ]
    }
  }
}
